<script>
/* ═══════════════ DADOS ═══════════════ */
const hoje = new Date().toISOString().slice(0,10);
const mesPassado = d => { let x=new Date(d); x.setMonth(x.getMonth()-1); return x.toISOString().slice(0,10); };

/* WORKSPACE */
const WORKSPACE_ID = (() => {
  let id = localStorage.getItem('fost_workspace_id');

  if(!id){
    id = 'crm_' + Math.random().toString(36).substring(2,10);
    localStorage.setItem('fost_workspace_id', id);
  }

  return id;
