function moverEtapa(index, direcao){

  const etapa = ETAPAS[index];

  if(!etapa || etapa.fixa) return;

  const limiteMaximo = ETAPAS.length - 3;

  let novaPosicao = index + direcao;

  if(novaPosicao < 0){
    novaPosicao = 0;
  }

  if(novaPosicao > limiteMaximo){
    novaPosicao = limiteMaximo;
  }

  if(index === novaPosicao){
    return;
  }

  ETAPAS.splice(index,1);
  ETAPAS.splice(novaPosicao,0,etapa);

  normalizarEtapas();

  salvarDados();

  renderPipeline();
  renderPipelineConfig();
  atualizarSelectEtapas();
}

function removerEtapa(chave){

  const etapa = ETAPAS.find(e => e.chave === chave);

  if(!etapa || etapa.fixa) return;

  const negociosNaEtapa = negocios.filter(n => n.etapa === chave);

  if(negociosNaEtapa.length){
    alert('Existem negócios nesta etapa.');
    return;
  }

  ETAPAS = ETAPAS.filter(e => e.chave !== chave);

  normalizarEtapas();

  renderPipeline();
  renderPipelineConfig();
  atualizarSelectEtapas();
}




function converterCSV(lista){

  if(!lista || !lista.length){
    return '';
  }

  const headers = Object.keys(lista[0]);

  const linhas = lista.map(item => {

    return headers.map(h => {

      let valor = item[h];

      if(typeof valor === 'object'){
        valor = JSON.stringify(valor);
      }

      valor = String(valor ?? '')
        .replace(/"/g,'""');

      return `"${valor}"`;

    }).join(',');

  });

  return [
    headers.join(','),
    ...linhas
  ].join('\n');
}

function baixarArquivo(nome, conteudo){

  const blob = new Blob(
    [conteudo],
    { type:'text/csv;charset=utf-8;' }
  );

  const link = document.createElement('a');

  const url = URL.createObjectURL(blob);

  link.href = url;
  link.download = nome;

  document.body.appendChild(link);

  link.click();

  document.body.removeChild(link);

  URL.revokeObjectURL(url);
}

function exportarCSV(tipo){

  let dados = [];
  let nome = '';

  if(tipo === 'contatos'){
    dados = contatos;
    nome = 'contatos.csv';
  }

  if(tipo === 'empresas'){

    dados = empresas.map(nomeEmpresa => {

      const contatosEmpresa = contatos.filter(c => c.empresa === nomeEmpresa);

      const negociosEmpresa = negocios.filter(n => n.empresa === nomeEmpresa);

      return {
        empresa:nomeEmpresa,
        contatos:contatosEmpresa.length,
        negocios:negociosEmpresa.length
      };
    });

    nome = 'empresas.csv';
  }

  if(tipo === 'negocios'){
    dados = negocios;
    nome = 'negocios.csv';
  }

  const csv = converterCSV(dados);

  baixarArquivo(nome, csv);
}


