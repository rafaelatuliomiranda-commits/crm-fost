/* ═══════════════ PIPELINE ═══════════════ */
function atualizarFiltroOwner(){
  const sel=document.getElementById('filtro-owner');
  const owners=getOwners();
  const val=sel.value;
  sel.innerHTML='<option value="">Todos os vendedores</option>'+owners.map(o=>`<option value="${o}"${o===val?' selected':''}>${o}</option>`).join('');
