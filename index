function setPeriod(p,btn){
  dashPeriod=p;
  document.querySelectorAll('.period-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  sincronizarStatusRelacionados();
  salvarDados();renderDashboard();
renderOwners();
