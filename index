  document.getElementById('empresa-contatos').innerHTML = contatosEmpresa.length
    ? contatosEmpresa.map(c => `
      <div style="padding:10px;border:1px solid var(--border);border-radius:8px;background:rgba(123,47,255,0.06);margin-bottom:8px;">
        <div style="font-size:13px;font-weight:700;color:var(--white);">${c.nome}</div>
        <div style="font-size:11px;color:var(--muted);margin-top:4px;">
          ${c.cargo || 'Sem cargo'} • ${c.telefone || 'Sem telefone'}
        </div>
        <div style="font-size:11px;color:var(--cyan);margin-top:2px;">
          ${c.email || 'Sem email'}
        </div>
      </div>
    `).join('')
    : '<div style="color:var(--muted-dim);font-size:12px;">Nenhum contato vinculado.</div>';

  document.getElementById('empresa-negocios').innerHTML = negociosEmpresa.length
    ? negociosEmpresa.map(n => `
      <div style="padding:10px;border:1px solid var(--border);border-radius:8px;background:rgba(123,47,255,0.06);margin-bottom:8px;">
        <div style="display:flex;justify-content:space-between;gap:10px;">
          <div>
            <div style="font-size:13px;font-weight:700;color:var(--white);">${n.titulo}</div>
            <div style="font-size:11px;color:var(--muted);margin-top:4px;">
              ${n.owner || 'Sem responsável'}
            </div>
          </div>

          <div style="text-align:right;">
            <div style="font-size:12px;font-weight:700;color:var(--cyan);">
              ${fmtFull(n.valor || 0)}
            </div>
            <div style="font-size:10px;color:var(--muted-dim);text-transform:uppercase;">
              ${n.etapa}
            </div>
          </div>
        </div>
      </div>
    `).join('')
    : '<div style="color:var(--muted-dim);font-size:12px;">Nenhum negócio vinculado.</div>';

  document.getElementById('modal-empresa').classList.add('open');
}

function fecharModalEmpresa(){
  document.getElementById('modal-empresa').classList.remove('open');
}

function salvarEmpresaEdicao(){
  const antigo = document.getElementById('empresa-antiga').value;
  const novo = document.getElementById('empresa-nome').value.trim();
  const setor = document.getElementById('empresa-setor').value.trim();
  const telefone = document.getElementById('empresa-telefone').value.trim();
  const info = document.getElementById('empresa-info').value.trim();

  if(!novo) return;

  empresas = empresas.map(e => e === antigo ? novo : e);

  contatos.forEach(c => {
    if(c.empresa === antigo){
      c.empresa = novo;
      c.setor = setor;
      c.telefone = telefone || c.telefone;
      c.info = info || c.info;
    }
  });

  negocios.forEach(n => {
    if(n.empresa === antigo){
      n.empresa = novo;
    }
  });

  sincronizarStatusRelacionados();
  salvarDados();
  atualizarSelectEmpresas();
  renderEmpresas();
  renderContatos();
  renderPipeline();

  fecharModalEmpresa();
}


