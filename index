  const idEx=parseInt(document.getElementById('c-id').value);
  const d={nome,status:document.getElementById('c-status').value,empresa:adicionarEmpresa(document.getElementById('c-empresa').value.trim()),cargo:document.getElementById('c-cargo').value,info:document.getElementById('c-info').value.trim(),telefone:document.getElementById('c-telefone').value.trim(),email:document.getElementById('c-email').value.trim()};
  if(idEx){const i=contatos.findIndex(c=>c.id===idEx);if(i!==-1)Object.assign(contatos[i],d);}
  else contatos.push({id:proxC++,...d});
  fecharModal('contato');sincronizarStatusRelacionados();
  salvarDados();renderEmpresas();
renderContatos();atualizarKPIs();

  const badge = document.getElementById('workspace-badge');
  if(badge){
    badge.textContent = WORKSPACE_ID.replace('crm_','');
  }
}


function sincronizarStatusRelacionados(){

  contatos.forEach(contato => {

    const negociosContato = negocios.filter(n =>
      n.empresa === contato.empresa
    );

    if(!negociosContato.length){
      contato.status = 'lead';
      return;
    }

    if(negociosContato.some(n => n.etapa === 'ganho')){
      contato.status = 'cliente';
      return;
    }

    if(negociosContato.some(n => n.etapa === 'negociacao')){
      contato.status = 'prospect';
      return;
    }

    if(negociosContato.some(n => n.etapa === 'qualificacao')){
      contato.status = 'prospect';
      return;
    }

    if(negociosContato.some(n => n.etapa === 'perdido')){
      contato.status = 'perdido';
      return;
    }

    contato.status = 'lead';
  });

}

