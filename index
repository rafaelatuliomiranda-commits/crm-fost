<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CRM — fost</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Bricolage+Grotesque:opsz,wght@12..96,700;12..96,800&display=swap" rel="stylesheet">
<style>
:root {
  --navy:#06006e; --purple:#7B2FFF; --purple-soft:#9B59FF; --cyan:#00D4FF;
  --white:#f0eeff; --muted:rgba(220,215,255,0.85); --muted-dim:rgba(200,195,255,0.48);
  --border:rgba(123,47,255,0.18); --border-mid:rgba(123,47,255,0.32);
  --card-bg:rgba(123,47,255,0.07); --card-hover:rgba(123,47,255,0.13);
  --danger-bg:rgba(255,60,60,0.08); --danger:#ff6b6b;
  --green:#34d399; --yellow:#fbbf24;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
body{background:var(--navy);color:var(--white);font-family:'Plus Jakarta Sans',sans-serif;font-weight:400;min-height:100vh;overflow-x:hidden;-webkit-font-smoothing:antialiased;}
body::before{content:'';position:fixed;inset:0;z-index:0;pointer-events:none;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");opacity:0.35;}
.orb{position:fixed;border-radius:50%;pointer-events:none;filter:blur(80px);z-index:0;}
.orb-1{width:500px;height:500px;background:var(--purple);top:-150px;right:-100px;opacity:0.2;}
.orb-2{width:350px;height:350px;background:var(--cyan);bottom:100px;left:-80px;opacity:0.08;}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:200;height:64px;padding:0 40px;display:flex;align-items:center;justify-content:space-between;background:rgba(6,0,110,0.9);backdrop-filter:blur(16px);border-bottom:1px solid var(--border);}
.nav-logo{font-family:'Bricolage Grotesque',sans-serif;font-size:22px;font-weight:800;letter-spacing:-0.02em;background:linear-gradient(135deg,var(--cyan),var(--purple-soft));-webkit-background-clip:text;-webkit-text-fill-color:transparent;user-select:none;}
.nav-tabs{display:flex;gap:4px;}
.nav-tab{display:flex;align-items:center;gap:7px;padding:7px 16px;border:none;border-radius:6px;cursor:pointer;font-family:'Plus Jakarta Sans',sans-serif;font-size:11px;font-weight:600;letter-spacing:0.07em;text-transform:uppercase;color:var(--muted-dim);background:none;transition:color .2s,background .2s;}
.nav-tab svg{width:13px;height:13px;flex-shrink:0;}
.nav-tab:hover{color:var(--white);background:rgba(123,47,255,0.1);}
.nav-tab.active{color:var(--cyan);background:rgba(0,212,255,0.08);}
.nav-badge{font-size:10px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--muted-dim);background:rgba(123,47,255,0.08);border:1px solid var(--border);border-radius:4px;padding:4px 12px;}

/* MAIN */
main{position:relative;z-index:1;max-width:1340px;margin:0 auto;padding:84px 36px 60px;}

/* KPIs */
.kpi-row{display:grid;grid-template-columns:repeat(8,1fr);gap:2px;background:var(--border);border-radius:10px;overflow:hidden;margin-bottom:32px;}
.kpi-card{background:var(--card-bg);padding:18px 14px;transition:background .25s;}
.kpi-card:hover{background:var(--card-hover);}
.kpi-label{display:flex;align-items:center;gap:5px;font-size:10px;font-weight:700;letter-spacing:0.13em;text-transform:uppercase;color:var(--muted-dim);margin-bottom:9px;}
.kpi-label svg{width:11px;height:11px;}
.kpi-value{font-family:'Bricolage Grotesque',sans-serif;font-size:24px;font-weight:800;line-height:1;color:var(--white);}
.kpi-value.cyan{background:linear-gradient(135deg,var(--cyan),var(--purple-soft));-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
.kpi-value.red{color:var(--danger);}
.kpi-value.green{color:var(--green);}
.kpi-sub{font-size:10px;color:var(--muted-dim);margin-top:5px;letter-spacing:.03em;}

/* TABS */
.tab-section{display:none;}.tab-section.active{display:block;}

/* TOOLBAR */
.toolbar{display:flex;gap:10px;align-items:center;margin-bottom:20px;flex-wrap:wrap;}
.toolbar-search{flex:1;min-width:180px;padding:9px 14px;background:rgba(123,47,255,0.07);border:1px solid var(--border);border-radius:6px;font-family:'Plus Jakarta Sans',sans-serif;font-size:13px;color:var(--white);outline:none;transition:border-color .2s,background .2s;}
.toolbar-search::placeholder{color:var(--muted-dim);}
.toolbar-search:focus{border-color:var(--border-mid);background:rgba(123,47,255,0.1);}
.toolbar-select{padding:9px 12px;background:rgba(123,47,255,0.07);border:1px solid var(--border);border-radius:6px;font-family:'Plus Jakarta Sans',sans-serif;font-size:12px;font-weight:600;color:var(--muted);outline:none;cursor:pointer;}
.toolbar-select option{background:#060060;}
.btn-add{display:flex;align-items:center;gap:8px;padding:9px 18px;background:linear-gradient(135deg,var(--purple),var(--purple-soft));border:none;border-radius:6px;cursor:pointer;font-family:'Plus Jakarta Sans',sans-serif;font-size:11px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:white;box-shadow:0 4px 16px rgba(123,47,255,.3);transition:transform .2s,box-shadow .2s;}
.btn-add:hover{transform:translateY(-1px);box-shadow:0 6px 24px rgba(123,47,255,.45);}
.btn-add svg{width:13px;height:13px;}

/* TABLE */
.table-wrap{background:var(--card-bg);border:1px solid var(--border);border-radius:10px;overflow:hidden;}
table{width:100%;border-collapse:collapse;font-size:13px;}
thead tr{background:rgba(123,47,255,0.08);}
th{text-align:left;padding:10px 14px;font-size:10px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--muted-dim);border-bottom:1px solid var(--border);}
td{padding:12px 14px;border-bottom:1px solid rgba(123,47,255,0.08);vertical-align:middle;color:var(--muted);}
tr:last-child td{border-bottom:none;}
tbody tr{transition:background .15s;}
tbody tr:hover td{background:rgba(123,47,255,0.07);}
.td-name{color:var(--white)!important;font-weight:600;}
.avatar{width:30px;height:30px;border-radius:7px;display:inline-flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;flex-shrink:0;margin-right:9px;border:1px solid rgba(123,47,255,0.25);}
.badge{display:inline-flex;align-items:center;gap:4px;padding:2px 9px;border-radius:4px;font-size:10px;font-weight:700;letter-spacing:.07em;text-transform:uppercase;}
.badge::before{content:'';width:4px;height:4px;border-radius:50%;background:currentColor;flex-shrink:0;}
.badge-lead{background:rgba(0,212,255,0.08);color:#00D4FF;border:1px solid rgba(0,212,255,0.2);}
.badge-prospect{background:rgba(251,191,36,0.08);color:#fbbf24;border:1px solid rgba(251,191,36,0.2);}
.badge-cliente{background:rgba(52,211,153,0.08);color:#34d399;border:1px solid rgba(52,211,153,0.2);}
.badge-perdido{background:rgba(255,107,107,0.08);color:#ff6b6b;border:1px solid rgba(255,107,107,0.2);}
.icon-btn{display:inline-flex;align-items:center;justify-content:center;background:none;border:none;cursor:pointer;padding:5px;border-radius:5px;color:var(--muted-dim);transition:color .2s,background .2s;}
.icon-btn:hover{color:var(--white);background:rgba(123,47,255,0.15);}
.icon-btn.danger:hover{color:var(--danger);background:var(--danger-bg);}
.icon-btn svg{width:14px;height:14px;}

/* PIPELINE */
.pipeline-label{display:flex;align-items:center;gap:8px;font-size:11px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--cyan);margin-bottom:18px;}
.pipeline-label::before{content:'';width:20px;height:2px;background:linear-gradient(to right,var(--cyan),var(--purple));display:block;}
.pipeline{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:2px;background:var(--border);border-radius:10px;overflow:hidden;align-items:start;}
.kanban-col{background:var(--card-bg);padding:16px 13px;min-height:460px;transition:background .15s;}
.kanban-col.drag-over{background:rgba(123,47,255,0.17);outline:1px solid var(--border-mid);outline-offset:-1px;}
.col-header{margin-bottom:13px;padding-bottom:11px;border-bottom:1px solid var(--border);}
.col-title{display:flex;align-items:center;justify-content:space-between;font-size:10px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--muted-dim);margin-bottom:3px;}
.col-count{background:rgba(123,47,255,0.15);border:1px solid var(--border);border-radius:3px;padding:1px 6px;font-size:11px;font-weight:700;color:var(--purple-soft);}
.col-total{font-family:'Bricolage Grotesque',sans-serif;font-size:16px;font-weight:800;background:linear-gradient(135deg,var(--cyan),var(--purple-soft));-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
.col-total.red{background:none;-webkit-text-fill-color:var(--danger);}
.col-total.green{background:none;-webkit-text-fill-color:var(--green);}

.deal-card{background:rgba(123,47,255,0.06);border:1px solid var(--border);border-radius:8px;padding:12px;margin-bottom:8px;cursor:grab;transition:border-color .2s,background .2s,opacity .2s,transform .15s;position:relative;overflow:hidden;user-select:none;}
.deal-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;opacity:0;transition:opacity .2s;}
.deal-card:hover{border-color:var(--border-mid);background:rgba(123,47,255,0.1);}
.deal-card:hover::before{opacity:1;}
.deal-card.dragging{opacity:.3;cursor:grabbing;transform:scale(0.96);}
.col-lead .deal-card::before{background:linear-gradient(90deg,var(--cyan),var(--purple));}
.col-qualif .deal-card::before{background:linear-gradient(90deg,#fbbf24,var(--purple));}
.col-negoc .deal-card::before{background:linear-gradient(90deg,var(--purple),var(--purple-soft));}
.col-ganho .deal-card::before{background:linear-gradient(90deg,#34d399,var(--cyan));}
.col-perdido .deal-card::before{background:linear-gradient(90deg,var(--danger),#7f1d1d);}

.deal-title{font-size:13px;font-weight:600;color:var(--white);margin-bottom:2px;line-height:1.3;}
.deal-owner{font-size:10px;color:var(--cyan);margin-bottom:6px;font-weight:600;letter-spacing:.03em;}
.deal-company{font-size:11px;color:var(--muted-dim);margin-bottom:8px;}
.deal-meta{display:flex;align-items:center;gap:6px;margin-bottom:8px;flex-wrap:wrap;}
.deal-tag{font-size:10px;color:var(--muted-dim);background:rgba(123,47,255,0.1);border:1px solid var(--border);border-radius:3px;padding:1px 6px;}
.deal-footer{display:flex;align-items:center;justify-content:space-between;}
.deal-value{font-family:'Bricolage Grotesque',sans-serif;font-size:14px;font-weight:800;background:linear-gradient(135deg,var(--cyan),var(--purple-soft));-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
.deal-value.red{background:none;-webkit-text-fill-color:var(--danger);}
.deal-actions{display:flex;gap:2px;}
.col-empty{font-size:11px;color:var(--muted-dim);text-align:center;padding:28px 0;letter-spacing:.04em;}

/* MODAL */
.modal-overlay{display:none;position:fixed;inset:0;z-index:500;background:rgba(6,0,80,0.8);backdrop-filter:blur(8px);align-items:center;justify-content:center;}
.modal-overlay.open{display:flex;}
.modal{background:#07005a;border:1px solid var(--border-mid);border-radius:12px;padding:28px;width:560px;max-width:96vw;max-height:92vh;overflow-y:auto;box-shadow:0 32px 80px rgba(0,0,10,.65);}
.modal-title{font-family:'Bricolage Grotesque',sans-serif;font-size:20px;font-weight:800;margin-bottom:24px;background:linear-gradient(135deg,var(--white),var(--muted));-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
.field{margin-bottom:14px;}
.field label{display:block;font-size:10px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--muted-dim);margin-bottom:6px;}
.field input,.field select,.field textarea{width:100%;padding:9px 12px;background:rgba(123,47,255,0.07);border:1px solid var(--border);border-radius:6px;font-family:'Plus Jakarta Sans',sans-serif;font-size:13px;color:var(--white);outline:none;transition:border-color .2s,background .2s;resize:vertical;}
.field textarea{min-height:76px;line-height:1.6;}
.field input::placeholder,.field textarea::placeholder{color:var(--muted-dim);}
.field input:focus,.field select:focus,.field textarea:focus{border-color:var(--border-mid);background:rgba(123,47,255,0.11);}
.field select option{background:#060060;}
.field input[type="date"]::-webkit-calendar-picker-indicator{filter:invert(0.6);}
.field-row{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.field-row3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;}
.modal-sep{height:1px;background:var(--border);margin:18px 0;}
.modal-section{font-size:10px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--cyan);margin-bottom:13px;display:flex;align-items:center;gap:8px;}
.modal-section::before{content:'';width:14px;height:2px;background:linear-gradient(to right,var(--cyan),var(--purple));display:block;}
.modal-actions{display:flex;justify-content:flex-end;gap:10px;margin-top:22px;padding-top:18px;border-top:1px solid var(--border);}
.btn-cancel{padding:8px 18px;background:rgba(123,47,255,0.07);border:1px solid var(--border);border-radius:6px;font-family:'Plus Jakarta Sans',sans-serif;font-size:11px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--muted-dim);cursor:pointer;transition:all .2s;}
.btn-cancel:hover{border-color:var(--border-mid);color:var(--white);}
.btn-save{padding:8px 22px;background:linear-gradient(135deg,var(--purple),var(--purple-soft));border:none;border-radius:6px;cursor:pointer;font-family:'Plus Jakarta Sans',sans-serif;font-size:11px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:white;box-shadow:0 4px 16px rgba(123,47,255,.3);transition:all .2s;}
.btn-save:hover{transform:translateY(-1px);box-shadow:0 6px 24px rgba(123,47,255,.45);}

/* NOTAS E ATIVIDADES dentro do modal */
.notes-list{display:flex;flex-direction:column;gap:8px;margin-bottom:12px;max-height:160px;overflow-y:auto;}
.note-item{background:rgba(123,47,255,0.08);border:1px solid var(--border);border-radius:6px;padding:10px 12px;font-size:12px;color:var(--muted);position:relative;}
.note-date{font-size:10px;color:var(--muted-dim);margin-bottom:4px;font-weight:600;}
.note-del{position:absolute;top:6px;right:6px;background:none;border:none;cursor:pointer;color:var(--muted-dim);font-size:14px;line-height:1;padding:2px;}
.note-del:hover{color:var(--danger);}
.add-note-row{display:flex;gap:8px;}
.add-note-row textarea{flex:1;padding:8px 10px;background:rgba(123,47,255,0.07);border:1px solid var(--border);border-radius:6px;font-family:'Plus Jakarta Sans',sans-serif;font-size:12px;color:var(--white);outline:none;resize:none;min-height:60px;}
.add-note-row textarea:focus{border-color:var(--border-mid);}
.btn-sm{padding:6px 12px;background:rgba(123,47,255,0.15);border:1px solid var(--border-mid);border-radius:5px;font-family:'Plus Jakarta Sans',sans-serif;font-size:11px;font-weight:700;color:var(--cyan);cursor:pointer;white-space:nowrap;transition:background .2s;}
.btn-sm:hover{background:rgba(123,47,255,0.25);}

.ativ-list{display:flex;flex-direction:column;gap:8px;margin-bottom:12px;max-height:160px;overflow-y:auto;}
.ativ-item{display:flex;align-items:flex-start;gap:10px;background:rgba(123,47,255,0.08);border:1px solid var(--border);border-radius:6px;padding:10px 12px;font-size:12px;}
.ativ-check{width:16px;height:16px;border-radius:4px;border:1px solid var(--border-mid);background:none;cursor:pointer;flex-shrink:0;margin-top:1px;accent-color:var(--cyan);}
.ativ-body{flex:1;}
.ativ-title{color:var(--white);font-weight:600;margin-bottom:2px;}
.ativ-title.done{text-decoration:line-through;color:var(--muted-dim);}
.ativ-date{font-size:10px;color:var(--muted-dim);}
.ativ-date.overdue{color:var(--danger);}
.ativ-del{background:none;border:none;cursor:pointer;color:var(--muted-dim);font-size:14px;padding:0 4px;}
.ativ-del:hover{color:var(--danger);}
.add-ativ-row{display:grid;grid-template-columns:1fr auto auto;gap:8px;align-items:end;}
.add-ativ-row input{padding:7px 10px;background:rgba(123,47,255,0.07);border:1px solid var(--border);border-radius:6px;font-family:'Plus Jakarta Sans',sans-serif;font-size:12px;color:var(--white);outline:none;}
.add-ativ-row input:focus{border-color:var(--border-mid);}
.add-ativ-row input[type="date"]::-webkit-calendar-picker-indicator{filter:invert(0.5);}

/* MODAL RÁPIDO de fechamento */
.mini-modal{background:#07005a;border:1px solid var(--border-mid);border-radius:12px;padding:24px;width:380px;max-width:95vw;box-shadow:0 32px 80px rgba(0,0,10,.65);}
.mini-modal h3{font-family:'Bricolage Grotesque',sans-serif;font-size:18px;font-weight:800;margin-bottom:20px;color:var(--white);}

/* DASHBOARD */
.dash-grid{display:grid;grid-template-columns:1fr 1fr;gap:2px;background:var(--border);border-radius:10px;overflow:hidden;margin-bottom:2px;}
.dash-grid-3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:2px;background:var(--border);border-radius:10px;overflow:hidden;margin-bottom:2px;}
.dash-full{background:var(--border);border-radius:10px;overflow:hidden;margin-bottom:2px;}
.dash-card{background:var(--card-bg);padding:24px;}
.dash-card-title{font-size:10px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--muted-dim);margin-bottom:18px;display:flex;align-items:center;gap:8px;}
.dash-card-title::before{content:'';width:14px;height:2px;background:linear-gradient(to right,var(--cyan),var(--purple));display:block;}

/* BAR CHART */
.chart-wrap{display:flex;align-items:flex-end;gap:6px;height:140px;margin-bottom:10px;}
.chart-col-g{display:flex;flex-direction:column;align-items:center;gap:0;flex:1;}
.bar-stack{display:flex;flex-direction:column;justify-content:flex-end;width:100%;gap:2px;}
.bar-seg{border-radius:3px 3px 0 0;min-height:2px;transition:height .4s;}
.bar-ganho{background:linear-gradient(180deg,var(--cyan),rgba(0,212,255,0.5));}
.bar-perdido{background:linear-gradient(180deg,var(--danger),rgba(255,107,107,0.5));border-radius:0;}
.bar-label{font-size:10px;color:var(--muted-dim);margin-top:6px;text-align:center;}

/* CICLO CHART */
.ciclo-row{display:flex;align-items:center;gap:10px;margin-bottom:8px;}
.ciclo-label{font-size:11px;color:var(--muted);width:90px;flex-shrink:0;}
.ciclo-bar-wrap{flex:1;height:8px;background:rgba(255,255,255,0.05);border-radius:4px;overflow:hidden;}
.ciclo-bar{height:100%;border-radius:4px;background:linear-gradient(90deg,var(--purple),var(--cyan));transition:width .5s;}
.ciclo-val{font-size:11px;font-weight:700;color:var(--white);width:44px;text-align:right;flex-shrink:0;}

/* STAT ROWS */
.stat-row{display:flex;align-items:center;justify-content:space-between;padding:10px 0;border-bottom:1px solid rgba(123,47,255,0.1);}
.stat-row:last-child{border-bottom:none;}
.stat-name{font-size:13px;color:var(--muted);}
.stat-val{font-family:'Bricolage Grotesque',sans-serif;font-size:16px;font-weight:800;color:var(--white);}
.stat-val.cyan{background:linear-gradient(135deg,var(--cyan),var(--purple-soft));-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
.stat-val.red{color:var(--danger);}

/* MOTIVOS */
.motivo-row{display:flex;align-items:center;gap:10px;margin-bottom:10px;}
.motivo-label{font-size:12px;color:var(--muted);flex:1;}
.motivo-bar-wrap{width:100px;height:6px;background:rgba(255,255,255,0.05);border-radius:3px;overflow:hidden;}
.motivo-bar{height:100%;border-radius:3px;background:linear-gradient(90deg,var(--danger),rgba(255,107,107,0.4));}
.motivo-count{font-size:11px;font-weight:700;color:var(--danger);width:20px;text-align:right;}

.empty-dash{text-align:center;padding:40px 20px;color:var(--muted-dim);font-size:13px;}

/* DASH FILTER */
.dash-filter{display:flex;gap:8px;margin-bottom:24px;align-items:center;flex-wrap:wrap;}
.dash-filter-label{font-size:11px;color:var(--muted-dim);font-weight:600;letter-spacing:.05em;}
.period-btn{padding:5px 14px;background:rgba(123,47,255,0.07);border:1px solid var(--border);border-radius:5px;font-family:'Plus Jakarta Sans',sans-serif;font-size:11px;font-weight:600;color:var(--muted-dim);cursor:pointer;transition:all .2s;}
.period-btn.active{background:rgba(0,212,255,0.1);border-color:rgba(0,212,255,0.3);color:var(--cyan);}

.empty-state{text-align:center;padding:48px 20px;color:var(--muted-dim);font-size:13px;}
.empty-icon{font-size:26px;margin-bottom:10px;opacity:.4;display:block;}
::-webkit-scrollbar{width:4px;}
::-webkit-scrollbar-track{background:transparent;}
::-webkit-scrollbar-thumb{background:rgba(123,47,255,.3);border-radius:2px;}

@media(max-width:1100px){.kpi-row{grid-template-columns:repeat(4,1fr);}.pipeline{grid-template-columns:repeat(3,1fr);}.dash-grid{grid-template-columns:1fr;}.dash-grid-3{grid-template-columns:1fr 1fr;}}
@media(max-width:700px){main{padding:84px 16px 48px;}nav{padding:0 16px;}.kpi-row{grid-template-columns:repeat(2,1fr);}.pipeline{grid-template-columns:repeat(2,1fr);}.dash-grid-3{grid-template-columns:1fr;}}


/* LOGIN */
.login-screen{
  position:fixed;
  inset:0;
  z-index:9999;
  background:linear-gradient(135deg,#06006e,#12005a);
  display:flex;
  align-items:center;
  justify-content:center;
}

.login-card{
  width:420px;
  max-width:92vw;
  background:rgba(123,47,255,0.08);
  border:1px solid rgba(123,47,255,0.25);
  border-radius:18px;
  padding:36px;
  backdrop-filter:blur(12px);
  box-shadow:0 30px 80px rgba(0,0,0,.45);
}

.login-logo{
  font-family:'Bricolage Grotesque',sans-serif;
  font-size:42px;
  font-weight:800;
  margin-bottom:12px;
  background:linear-gradient(135deg,var(--cyan),var(--purple-soft));
  -webkit-background-clip:text;
  -webkit-text-fill-color:transparent;
}

.login-sub{
  font-size:14px;
  color:var(--muted);
  margin-bottom:24px;
  line-height:1.5;
}

.login-input{
  width:100%;
  padding:14px 16px;
  border-radius:10px;
  border:1px solid var(--border);
  background:rgba(123,47,255,0.08);
  color:white;
  font-size:15px;
  outline:none;
  margin-bottom:14px;
}

.login-input:focus{
  border-color:var(--cyan);
}

.login-btn{
  width:100%;
  padding:14px;
  border:none;
  border-radius:10px;
  background:linear-gradient(135deg,var(--purple),var(--purple-soft));
  color:white;
  font-size:14px;
  font-weight:700;
  cursor:pointer;
}

.login-error{
  margin-top:12px;
  font-size:12px;
  color:#ff8f8f;
  display:none;
}

.logout-btn{
  padding:7px 14px;
  border:none;
  border-radius:6px;
  background:rgba(255,255,255,0.08);
  color:var(--muted);
  cursor:pointer;
  font-size:11px;
  font-weight:700;
  letter-spacing:.08em;
  text-transform:uppercase;
}

.logout-btn:hover{
  background:rgba(255,255,255,0.12);
  color:white;
}

</style>
</head>
