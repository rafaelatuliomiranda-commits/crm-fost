}

function getMeses(n){
  const meses=[];
  const d=new Date();
  for(let i=n-1;i>=0;i--){
    const x=new Date(d.getFullYear(),d.getMonth()-i,1);
    meses.push(`${x.getFullYear()}-${String(x.getMonth()+1).padStart(2,'0')}`);
  }
  return meses;
}

function renderDashboard(){
  const meses=getMeses(dashPeriod);
  const fechados=negocios.filter(n=>(n.etapa==='ganho'||n.etapa==='perdido')&&n.dataFechamento);

  // Resultado por mês
  const porMes=meses.map(ym=>{
    const ganhos=fechados.filter(n=>n.etapa==='ganho'&&n.dataFechamento&&n.dataFechamento.slice(0,7)===ym);
    const perdidos=fechados.filter(n=>n.etapa==='perdido'&&n.dataFechamento&&n.dataFechamento.slice(0,7)===ym);
    return {ym,vGanho:ganhos.reduce((a,n)=>a+(+(n.valorFechado||n.valor)||0),0),vPerdido:perdidos.reduce((a,n)=>a+(+n.valor||0),0),qtdG:ganhos.length,qtdP:perdidos.length};
  });
  const maxVal=Math.max(...porMes.map(m=>m.vGanho+m.vPerdido),1);

  // Ciclo por etapa
  const etapasCiclo=['lead','qualificacao','negociacao'];
  const cicloPorEtapa=etapasCiclo.map(et=>{
    const dias=fechados.filter(n=>n.historico[et]).map(n=>{
      const entrada=n.historico[et];
      // próxima etapa com data
      const prox=['qualificacao','negociacao','ganho','perdido'].find(e=>e!==et&&n.historico[e]);
      const saida=prox?n.historico[prox]:n.dataFechamento;
      return diffDias(entrada,saida);
    }).filter(d=>d!==null&&d>=0);
    return {et,dias,media:dias.length?Math.round(dias.reduce((a,b)=>a+b,0)/dias.length):null};
  });
  const maxCiclo=Math.max(...cicloPorEtapa.map(e=>e.media||0),1);
  const labelEtapa={lead:'Lead',qualificacao:'Qualificação',negociacao:'Negociação'};

  // Top proprietários
  const ownerMap={};
  negocios.filter(n=>n.etapa==='ganho'&&n.owner).forEach(n=>{
    ownerMap[n.owner]=(ownerMap[n.owner]||0)+(+(n.valorFechado||n.valor)||0);
  });
  const topOwners=Object.entries(ownerMap).sort((a,b)=>b[1]-a[1]).slice(0,5);
  const maxOwner=Math.max(...topOwners.map(o=>o[1]),1);

  // Motivos de perda
  const motivoMap={};
  negocios.filter(n=>n.etapa==='perdido'&&n.motivo).forEach(n=>{ motivoMap[n.motivo]=(motivoMap[n.motivo]||0)+1; });
  const topMotivos=Object.entries(motivoMap).sort((a,b)=>b[1]-a[1]);
  const maxMotivo=Math.max(...topMotivos.map(m=>m[1]),1);

  // Ticket médio por mês
  const ticketMes=porMes.map(m=>({ym:m.ym,ticket:m.qtdG?Math.round(m.vGanho/m.qtdG):0}));

  const html=`
    <!-- Gráfico resultado por mês -->
    <div class="dash-full" style="margin-bottom:2px;">
      <div class="dash-card">
        <div class="dash-card-title">Resultado mensal — Ganhos vs. Perdidos (R$)</div>
        <div class="chart-wrap" id="chart-mensal">
          ${porMes.map(m=>{
            const hG=m.vGanho?Math.round((m.vGanho/maxVal)*120):0;
            const hP=m.vPerdido?Math.round((m.vPerdido/maxVal)*120):0;
            return `<div class="chart-col-g">
              <div class="bar-stack" style="height:130px;justify-content:flex-end">
                ${m.vPerdido?`<div class="bar-seg bar-perdido" style="height:${hP}px" title="${fmtFull(m.vPerdido)} perdido"></div>`:''}
                ${m.vGanho?`<div class="bar-seg bar-ganho" style="height:${hG}px" title="${fmtFull(m.vGanho)} ganho"></div>`:''}
                ${!m.vGanho&&!m.vPerdido?`<div style="height:4px;background:rgba(123,47,255,0.15);border-radius:2px;width:100%"></div>`:''}
              </div>
              <div class="bar-label">${fmtMes(m.ym)}</div>
            </div>`;
          }).join('')}
        </div>
        <div style="display:flex;gap:20px;margin-top:4px;">
          <span style="font-size:11px;color:var(--cyan);display:flex;align-items:center;gap:5px;"><span style="width:10px;height:10px;border-radius:2px;background:var(--cyan);display:inline-block;"></span>Ganho</span>
          <span style="font-size:11px;color:var(--danger);display:flex;align-items:center;gap:5px;"><span style="width:10px;height:10px;border-radius:2px;background:var(--danger);display:inline-block;"></span>Perdido</span>
        </div>
      </div>
    </div>

    <div class="dash-grid" style="margin-bottom:2px;">
      <!-- Ciclo por etapa -->
      <div class="dash-card">
        <div class="dash-card-title">Ciclo médio por etapa (dias)</div>
        ${cicloPorEtapa.map(e=>`
          <div class="ciclo-row">
            <div class="ciclo-label">${labelEtapa[e.et]}</div>
            <div class="ciclo-bar-wrap"><div class="ciclo-bar" style="width:${e.media?Math.round(e.media/maxCiclo*100):0}%"></div></div>
            <div class="ciclo-val">${e.media!==null?e.media+'d':'—'}</div>
          </div>`).join('')}
        ${cicloPorEtapa.every(e=>e.media===null)?'<div class="empty-dash">Sem dados suficientes.<br>Mova negócios pelo funil para calcular.</div>':''}
      </div>

      <!-- Ticket médio por mês -->
      <div class="dash-card">
        <div class="dash-card-title">Ticket médio — negócios ganhos por mês</div>
        ${ticketMes.filter(m=>m.ticket>0).length?ticketMes.filter(m=>m.ticket>0).slice(-6).map(m=>`
          <div class="stat-row">
            <div class="stat-name">${fmtMes(m.ym)}</div>
            <div class="stat-val cyan">${fmtFull(m.ticket)}</div>
          </div>`).join(''):'<div class="empty-dash">Sem fechamentos no período.</div>'}
      </div>
    </div>

    <div class="dash-grid-3">
      <!-- Top vendedores -->
      <div class="dash-card">
        <div class="dash-card-title">Top vendedores — valor ganho</div>
        ${topOwners.length?topOwners.map(([o,v])=>`
          <div class="ciclo-row">
            <div class="ciclo-label" style="width:110px">${o}</div>
            <div class="ciclo-bar-wrap"><div class="ciclo-bar" style="width:${Math.round(v/maxOwner*100)}%;background:linear-gradient(90deg,var(--purple-soft),var(--cyan))"></div></div>
            <div class="ciclo-val" style="width:56px;font-size:10px">${fmtK(v)}</div>
          </div>`).join(''):'<div class="empty-dash">Sem dados ainda.</div>'}
      </div>

      <!-- Motivos de perda -->
      <div class="dash-card">
        <div class="dash-card-title">Motivos de perda</div>
        ${topMotivos.length?topMotivos.map(([m,c])=>`
          <div class="motivo-row">
            <div class="motivo-label">${m}</div>
            <div class="motivo-bar-wrap"><div class="motivo-bar" style="width:${Math.round(c/maxMotivo*100)}%"></div></div>
            <div class="motivo-count">${c}</div>
          </div>`).join(''):'<div class="empty-dash">Nenhuma perda registrada.</div>'}
      </div>

      <!-- Ciclo total + conv -->
      <div class="dash-card">
        <div class="dash-card-title">Métricas de eficiência</div>
        ${(()=>{
          const dec=negocios.filter(n=>(n.etapa==='ganho'||n.etapa==='perdido')&&n.dataEntrada&&n.dataFechamento);
          const cicloTotal=dec.length?Math.round(dec.reduce((a,n)=>a+diffDias(n.dataEntrada,n.dataFechamento),0)/dec.length):null;
          const ganhos=negocios.filter(n=>n.etapa==='ganho');
          const perdidos=negocios.filter(n=>n.etapa==='perdido');
          const convQ=ganhos.length+perdidos.length?Math.round(ganhos.length/(ganhos.length+perdidos.length)*100):0;
          const tG=ganhos.reduce((a,n)=>a+(+(n.valorFechado||n.valor)||0),0);
          const tP=perdidos.reduce((a,n)=>a+(+n.valor||0),0);
          const convV=tG+tP?Math.round(tG/(tG+tP)*100):0;
          const ticketMedio=ganhos.length?Math.round(tG/ganhos.length):0;
          return `
            <div class="stat-row"><div class="stat-name">Ciclo médio total</div><div class="stat-val">${cicloTotal!==null?cicloTotal+' dias':'—'}</div></div>
            <div class="stat-row"><div class="stat-name">Conv. por quantidade</div><div class="stat-val">${convQ}%</div></div>
            <div class="stat-row"><div class="stat-name">Conv. por valor (R$)</div><div class="stat-val cyan">${convV}%</div></div>
            <div class="stat-row"><div class="stat-name">Ticket médio (ganhos)</div><div class="stat-val cyan">${fmtFull(ticketMedio)}</div></div>
            <div class="stat-row"><div class="stat-name">Total fechamentos</div><div class="stat-val">${ganhos.length+perdidos.length}</div></div>
          `;
        })()}
      </div>
    </div>
  `;
  document.getElementById('dashboard-content').innerHTML=html;
}

