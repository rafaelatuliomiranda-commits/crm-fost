/* ═══════════════ MODAIS ═══════════════ */
let negEditando=null; // referência ao negócio sendo editado (para notas/ativ em tempo real)

function abrirModal(tipo){
  if(tipo==='contato'){
    document.getElementById('modal-contato-titulo').textContent='Novo contato';
    document.getElementById('c-id').value='';
    ['c-nome','c-empresa','c-telefone','c-email','c-info'].forEach(id=>document.getElementById(id).value='');
    document.getElementById('c-status').value='lead';
    atualizarSelectEmpresas();
    document.getElementById('c-cargo').value='';
  }
  if(tipo==='negocio'){
    negEditando={id:null,notas:[],atividades:[],historico:{lead:hoje,qualificacao:null,negociacao:null,ganho:null,perdido:null}};
    document.getElementById('modal-negocio-titulo').textContent='Novo negócio';
    document.getElementById('n-id').value='';
    ['n-titulo','n-empresa','n-owner','n-valor','n-valor-fechado'].forEach(id=>document.getElementById(id).value='');
    document.getElementById('n-etapa').value='lead';
    renderContatosAssociados(document.getElementById('n-empresa').value);
    atualizarSelectEmpresas();
    document.getElementById('n-data-entrada').value=hoje;
    document.getElementById('n-data-fechamento').value='';
    renderNotasModal();renderAtivModal();
  }
  document.getElementById('modal-'+tipo).classList.add('open');
}
function fecharModal(tipo){document.getElementById('modal-'+tipo).classList.remove('open');}
function fecharModalFora(e,tipo){if(e.target===document.getElementById('modal-'+tipo))fecharModal(tipo);}

/* ═══════════════ NOTAS E ATIVIDADES (no modal) ═══════════════ */
function renderNotasModal(){
  const list=document.getElementById('notes-list');
  if(!negEditando||!negEditando.notas.length){list.innerHTML='<div style="font-size:12px;color:var(--muted-dim);padding:4px 0">Nenhuma nota ainda.</div>';return;}
  list.innerHTML=negEditando.notas.map(n=>`
    <div class="note-item">
      <div class="note-date">${n.data}</div>
      <div>${n.texto}</div>
      <button class="note-del" onclick="removerNota(${n.id})">×</button>
    </div>`).join('');
}
function adicionarNota(){
  const txt=document.getElementById('nota-nova').value.trim();
  if(!txt||!negEditando)return;
  const maxId=negEditando.notas.length?Math.max(...negEditando.notas.map(n=>n.id)):0;
  negEditando.notas.push({id:maxId+1,texto:txt,data:hoje});
  document.getElementById('nota-nova').value='';
  renderNotasModal();
}
function removerNota(id){if(negEditando)negEditando.notas=negEditando.notas.filter(n=>n.id!==id);renderNotasModal();}

function renderAtivModal(){
  const list=document.getElementById('ativ-list');
  if(!negEditando||!negEditando.atividades.length){list.innerHTML='<div style="font-size:12px;color:var(--muted-dim);padding:4px 0">Nenhuma atividade ainda.</div>';return;}
  list.innerHTML=negEditando.atividades.map(a=>{
    const atrasada=!a.done&&a.data&&a.data<hoje;
    return `<div class="ativ-item">
      <input type="checkbox" class="ativ-check" ${a.done?'checked':''} onchange="toggleAtiv(${a.id})">
      <div class="ativ-body">
        <div class="ativ-title${a.done?' done':''}">${a.titulo}</div>
        ${a.data?`<div class="ativ-date${atrasada?' overdue':''}">${a.data}${atrasada?' · atrasada':''}</div>`:''}
      </div>
      <button class="ativ-del" onclick="removerAtiv(${a.id})">×</button>
    </div>`;
  }).join('');
}
function adicionarAtividade(){
  const titulo=document.getElementById('ativ-nova').value.trim();
  if(!titulo||!negEditando)return;
  const maxId=negEditando.atividades.length?Math.max(...negEditando.atividades.map(a=>a.id)):0;
  negEditando.atividades.push({id:maxId+1,titulo,data:document.getElementById('ativ-data').value,done:false});
  document.getElementById('ativ-nova').value='';
  document.getElementById('ativ-data').value='';
  renderAtivModal();
}
function toggleAtiv(id){if(negEditando){const a=negEditando.atividades.find(a=>a.id===id);if(a)a.done=!a.done;}renderAtivModal();}
function removerAtiv(id){if(negEditando)negEditando.atividades=negEditando.atividades.filter(a=>a.id!==id);renderAtivModal();}

