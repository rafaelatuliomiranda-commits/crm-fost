  salvarDados();
  renderOwners();
atualizarSelectOwners();
  atualizarFiltroOwner();
  atualizarSelectOwners();
  renderPipeline();
}


/* ═══════════════ EMPRESAS ═══════════════ */

function renderEmpresas(){
  const tbody = document.getElementById('tabela-empresas');

  if(!tbody) return;

  const empresasDetalhadas = empresas.map(emp=>{

    const contatosEmpresa = contatos.filter(c=>c.empresa===emp);
    const negociosEmpresa = negocios.filter(n=>n.empresa===emp);

    const primeiroContato = contatosEmpresa[0] || {};

    return {
      nome: emp,
      contatos: contatosEmpresa.length,
      negocios: negociosEmpresa.length,
      setor: primeiroContato.setor || '—',
      telefone: primeiroContato.telefone || '—'
    };

  });

  tbody.innerHTML = empresasDetalhadas.map(emp => `
    <tr style="cursor:pointer" onclick="event.stopPropagation(); editarEmpresa('${emp.nome}')">
      <td class="td-name">${emp.nome}</td>
      <td>${emp.setor}</td>
      <td>${emp.telefone}</td>
      <td>${emp.contatos}</td>
      <td>${emp.negocios}</td>

      <td>
        <button
          class="icon-btn danger"
          onclick="event.stopPropagation(); excluirEmpresa('${emp.nome}')"
          title="Excluir empresa"
        >
          ${SVG_DEL}
        </button>
      </td>
    </tr>
  `).join('');
}




function novaEmpresaManual(){
  const nome = prompt('Digite o nome da empresa:');

  if(!nome) return;

  adicionarEmpresa(nome);

  renderEmpresas();
}

function excluirEmpresa(nomeEmpresa){

  const possuiContatos = contatos.some(c => c.empresa === nomeEmpresa);
  const possuiNegocios = negocios.some(n => n.empresa === nomeEmpresa);

  let mensagem = `Deseja excluir a empresa "${nomeEmpresa}"?`;

  if(possuiContatos || possuiNegocios){
    mensagem += '\n\nTodos os contatos e negócios vinculados também serão removidos.';
  }

  if(!confirm(mensagem)) return;

  contatos = contatos.filter(c => c.empresa !== nomeEmpresa);
  negocios = negocios.filter(n => n.empresa !== nomeEmpresa);
  empresas = empresas.filter(e => e !== nomeEmpresa);

  sincronizarStatusRelacionados();
  salvarDados();

  atualizarSelectEmpresas();
  renderEmpresas();
  renderContatos();
  renderPipeline();
  renderDashboard();
renderOwners();
atualizarSelectOwners();
  atualizarKPIs();
}


/* ═══════════════ CONTATOS ═══════════════ */
