function atualizarKPIs(){
  const ganhos  =negocios.filter(n=>n.etapa==='ganho');
  const perdidos=negocios.filter(n=>n.etapa==='perdido');
  const ativos  =negocios.filter(n=>n.etapa!=='ganho'&&n.etapa!=='perdido');
  const tPipe=ativos.reduce((a,n)=>a+(+n.valor||0),0);
  const tGanho=ganhos.reduce((a,n)=>a+(+(n.valorFechado||n.valor)||0),0);
  const tPerd=perdidos.reduce((a,n)=>a+(+n.valor||0),0);
  const decididos=ganhos.length+perdidos.length;
  const convQtd=decididos?Math.round(ganhos.length/decididos*100):0;
  const decVal=tGanho+tPerd;
  const convVal=decVal?Math.round(tGanho/decVal*100):0;

  // ciclo médio total (entrada → fechamento) apenas decididos com datas
  const ciclos=negocios.filter(n=>(n.etapa==='ganho'||n.etapa==='perdido')&&n.dataEntrada&&n.dataFechamento).map(n=>diffDias(n.dataEntrada,n.dataFechamento));
  const cicloMedio=ciclos.length?Math.round(ciclos.reduce((a,b)=>a+b,0)/ciclos.length):null;

  document.getElementById('kpi-total').textContent=contatos.length;
  document.getElementById('kpi-deals').textContent=negocios.length;
  document.getElementById('kpi-pipeline').textContent=fmtFull(tPipe);
  document.getElementById('kpi-ganhos').textContent=fmtFull(tGanho);
  document.getElementById('kpi-perdidos').textContent=fmtFull(tPerd);
  document.getElementById('kpi-ciclo').textContent=cicloMedio!==null?cicloMedio+' d':'— d';
  document.getElementById('kpi-conv-qtd').textContent=convQtd+'%';
  document.getElementById('kpi-conv-val').textContent=convVal+'%';
}


