function renderPipeline(){
  atualizarFiltroOwner();
  const ownerFilter=document.getElementById('filtro-owner').value;
  const container=document.getElementById('pipeline-kanban');
  container.innerHTML=ETAPAS.map(et=>{
    let cards=negocios.filter(n=>n.etapa===et.chave&&(!ownerFilter||n.owner===ownerFilter));
    const total=cards.reduce((a,n)=>a+(+(n.etapa==='ganho'?n.valorFechado||n.valor:n.valor)||0),0);
    const isPerd=et.chave==='perdido';
    const isGanho=et.chave==='ganho';
    const tCls=isPerd?'col-total red':isGanho?'col-total green':'col-total';
    const cardsHTML=cards.length?cards.map(n=>{
      const dataInicioEtapa = n.historico?.[et.chave] || hoje;
      const diasNaEtapa = diffDias(dataInicioEtapa, hoje);
      return `<div class="deal-card" onclick="editarNegocio(${n.id})" style="cursor:pointer;" draggable="true" data-id="${n.id}" ondragstart="onDragStart(event,${n.id})" ondragend="onDragEnd(event)">
        <div class="deal-title">${n.titulo}</div>
        
        <div class="deal-company">${n.empresa||''}</div>

        ${diasNaEtapa !== null ? `
          <div class="deal-meta">
            <div class="deal-tag">
              ⏱ ${diasNaEtapa}d na etapa
            </div>
          </div>
        ` : ''}

        ${n.previsaoFechamento?`<div class="deal-tag">📅 ${n.previsaoFechamento}</div>`:''}

        <div class="deal-footer">
          <div class="deal-value${isPerd?' red':''}">${fmtK(isGanho&&n.valorFechado?n.valorFechado:n.valor)}</div>
          <div class="deal-actions">
            
            <button class="icon-btn danger" onclick="event.stopPropagation(); excluirNegocio(${n.id})" title="Remover">${SVG_DEL}</button>
          </div>
        </div>
      </div>`;
    }).join(''):`<div class="col-empty">Sem negócios</div>`;
    return `<div class="kanban-col ${et.cls}" data-etapa="${et.chave}" ondragover="onDragOver(event)" ondragleave="onDragLeave(event)" ondrop="onDrop(event,'${et.chave}')">
      <div class="col-header">
        <div class="col-title">${et.label}<span class="col-count">${cards.length}</span></div>
        <div class="${tCls}">${total?fmtK(total):'—'}</div>
      </div>${cardsHTML}
    </div>`;
  }).join('');
}

/* ═══════════════ DRAG & DROP ═══════════════ */
let dragId=null;
function onDragStart(e,id){dragId=id;e.dataTransfer.effectAllowed='move';setTimeout(()=>{const el=document.querySelector(`[data-id="${id}"]`);if(el)el.classList.add('dragging');},0);}
function onDragEnd(e){document.querySelectorAll('.deal-card.dragging').forEach(c=>c.classList.remove('dragging'));document.querySelectorAll('.kanban-col').forEach(c=>c.classList.remove('drag-over'));}
function onDragOver(e){e.preventDefault();e.dataTransfer.dropEffect='move';e.currentTarget.classList.add('drag-over');}
function onDragLeave(e){if(!e.currentTarget.contains(e.relatedTarget))e.currentTarget.classList.remove('drag-over');}
function onDrop(e,etapa){
  e.preventDefault();
  e.currentTarget.classList.remove('drag-over');
  if(dragId===null)return;
  const neg=negocios.find(n=>n.id===dragId);
  if(!neg||neg.etapa===etapa)return;
  // Se for para ganho ou perdido, abre modal de fechamento
  if(etapa==='ganho'||etapa==='perdido'){
    document.getElementById('f-id').value=dragId;
    document.getElementById('f-etapa').value=etapa;
    document.getElementById('f-valor').value=neg.valorFechado||neg.valor||'';
    document.getElementById('f-data').value=hoje;
    document.getElementById('f-motivo').value='';
    const mWrap=document.getElementById('f-motivo-wrap');
    mWrap.style.display=etapa==='perdido'?'block':'none';
    document.getElementById('fechamento-titulo').textContent=etapa==='ganho'?'🎉 Confirmar ganho':'Registrar perda';
    document.getElementById('modal-fechamento').classList.add('open');
  } else {
    neg.historico[etapa]=hoje;
    neg.etapa=etapa;
    sincronizarStatusRelacionados();
  salvarDados();renderPipeline();atualizarKPIs();

  const badge = document.getElementById('workspace-badge');
  if(badge){
    badge.textContent = WORKSPACE_ID.replace('crm_','');
  }
  }
}

function confirmarFechamento(){
  const id=parseInt(document.getElementById('f-id').value);
  const etapa=document.getElementById('f-etapa').value;
  const neg=negocios.find(n=>n.id===id);
  if(!neg)return;
  neg.etapa=etapa;
  neg.valorFechado=parseFloat(document.getElementById('f-valor').value)||neg.valor;
  neg.dataFechamento=document.getElementById('f-data').value||hoje;
  neg.motivo=document.getElementById('f-motivo').value||'';
  if(!neg.historico[etapa])neg.historico[etapa]=neg.dataFechamento;
  fecharModal('fechamento');
  sincronizarStatusRelacionados();
  salvarDados();renderPipeline();atualizarKPIs();

  const badge = document.getElementById('workspace-badge');
  if(badge){
    badge.textContent = WORKSPACE_ID.replace('crm_','');
  }
  if(document.getElementById('sec-dashboard').classList.contains('active'))renderDashboard();
renderOwners();
atualizarSelectOwners();
}

